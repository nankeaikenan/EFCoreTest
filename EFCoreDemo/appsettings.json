{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=EFCoreDemo;Uid=root;Pwd=123456;"
  },

  /*
    JWT 配置说明：
    - SecretKey：用于签名 JWT 的对称密钥，必须 ≥ 32 字符（HS256 要求）
                 ⚠️ 生产环境：应从环境变量 / Azure Key Vault / AWS Secrets 读取，绝不能提交到 Git！
    - Issuer：Token 颁发者标识，客户端可据此验证 Token 来源
    - Audience：Token 受众标识，客户端可据此验证 Token 是否颁发给自己
    - AccessTokenExpirationMinutes：Access Token 有效期（分钟）
                                    企业建议：15~60 分钟（越短越安全，依赖 Refresh Token 续签）
    - RefreshTokenExpirationDays：Refresh Token 有效期（天）
                                   企业建议：7~30 天，记住"我"功能可设置更长
  */
  "JwtSettings": {
    "SecretKey": "EFCoreDemoSuperSecretKey@2026!JWT#HS256",
    "Issuer": "EFCoreDemo",
    "Audience": "EFCoreDemo",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
}

